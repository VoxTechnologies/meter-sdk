{
  "name": "@meter-mcp/mcp",
  "version": "0.1.0",
  "description": "Drop-in metered tool wrappers for Model Context Protocol servers",
  "keywords": ["mcp", "model-context-protocol", "billing", "payments", "credits"],
  "author": "Yoichiro Hara",
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts",
    "prepack": "npm run build"
  },
  "dependencies": { "@meter-mcp/sdk": "^0.1.0" },
  "engines": { "node": ">=20" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masterleopold/meter-sdk.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/masterleopold/meter-sdk/tree/main/packages/mcp#readme",
  "bugs": { "url": "https://github.com/masterleopold/meter-sdk/issues" },
  "publishConfig": { "access": "public", "registry": "https://registry.npmjs.org" },
  "license": "MIT"
}
