{
  "name": "@meter-mcp/sdk",
  "version": "0.3.0",
  "description": "Server-side SDK for Meter prepaid credits and MCP usage billing",
  "keywords": [
    "mcp",
    "billing",
    "payments",
    "prepaid",
    "credits",
    "usage-based-billing"
  ],
  "author": "Yoichiro Hara",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masterleopold/meter-sdk.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/masterleopold/meter-sdk/tree/main/packages/sdk#readme",
  "bugs": {
    "url": "https://github.com/masterleopold/meter-sdk/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "license": "MIT"
}
